\@writefile{lof}{\contentsline {figure}{\numberline {2.4}{\ignorespaces CoT delta: изменение EMA при переходе от Neutral к CoT промпту. Для проприетарных моделей (синий) CoT даёт прирост у всех трёх моделей. Для открытых моделей (оранжевый) две модели демонстрируют отрицательный delta. Модели отсортированы по убыванию delta.}}{34}{}\protected@file@percent }
\newlabel{fig:cot_delta}{{2.4}{34}{Результаты и анализ}{figure.2.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2.5}{\ignorespaces Связь EMA и Consistency Rate в FL Neutral. Идеальная модель находилась бы в правом верхнем углу (высокая точность + высокая стабильность). Топ-модели кластеризуются вблизи этого угла, в то время как слабые модели демонстрируют различные профили: низкая точность + низкая стабильность (\texttt  {gemma-3-12b-it}), средняя точность + низкая стабильность (\texttt  {gemma-3-27b-it}).}}{34}{}\protected@file@percent }
\newlabel{fig:ema_vs_consistency}{{2.5}{34}{Результаты и анализ}{figure.2.5}{}}
